{
  "name": "AutoOpsScaler",
  "dockerFile": "Dockerfile",
  "runArgs": [
    "--privileged"
  ],
  "mounts": [
    "source=autoopsscaler-dind,target=/var/lib/docker,type=volume"
  ],
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "/bin/bash"
          }
        }
      }
    }
  },
  "postCreateCommand": "echo '[INFO] Container initialized', open a new terminal",
  "remoteUser": "root"
}
