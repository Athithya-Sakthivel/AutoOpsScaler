{
  "name": "AutoOpsScaler",

  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  "runArgs": [
    "--privileged"
  ],

  // ✅ Universal mounts (no duplicate workspace)
  "mounts": [
    // Shared cache for Python, Pip, etc.
    "source=llmops-cache,target=/root/.cache,type=volume",

    // Persist VSCode extensions
    "source=llmops-vscode,target=/root/.vscode-server,type=volume",

    // Host docker.sock bind mount (skip on Windows + Docker Desktop)
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],

  // VS Code auto-mounts your project folder to this
  "workspaceFolder": "/workspaces/AutoOpsScaler",

  "remoteUser": "root",
  "overrideCommand": true,

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "remote.containers.logLevel": "trace"
      }
    }
  },

  "remoteEnv": {
    "DEBUG": "true"
  },

  "postCreateCommand": "echo '✅ Container ready'"
}
