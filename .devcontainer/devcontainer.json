{
  "name": "AutoOpsScaler",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "runArgs": [
    "--privileged",  // Required for DinD
    "--init"         // Ensures proper signal handling
  ],
  "mounts": [
    // Internal volumes
    "source=llmops-cache,target=/root/.cache,type=volume",
    "source=llmops-vscode,target=/root/.vscode-server,type=volume",

    // Bind the project workspace universally (macOS/Linux/WSL2)
    "source=${localWorkspaceFolder},target=/workspaces/AutoOpsScaler,type=bind,consistency=cached",

    // Optional: Only mount if host supports docker.sock
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind,consistency=cached"
  ],
  "workspaceFolder": "/workspaces/AutoOpsScaler",
  "remoteUser": "root",
  "overrideCommand": false,

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "remote.containers.logLevel": "trace"
      }
    }
  },

  "features": {
    // Optional: Auto install Docker CLI and dind
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest"
    }
  },

  "remoteEnv": {
    "DEBUG": "true"
  },

  "postCreateCommand": "echo '✅ DevContainer ready - Close this terminal'"
}
