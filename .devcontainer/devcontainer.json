{
  "name": "AutoOpsScaler",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "runArgs": [
    "--privileged"
  ],
  "mounts": [
    "source=llmops-cache,target=/root/.cache,type=volume",
    "source=llmops-vol,target=/workspace,type=volume",
    "source=llmops-vscode,target=/root/.vscode-server,type=volume",
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "remoteUser": "root",
  "overrideCommand": true,
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "remote.containers.logLevel": "trace"
      }
    }
  },
  "remoteEnv": {
    "DEBUG": "true"
  },
  "postCreateCommand": "echo '✅ Close this terminal now'"
}
