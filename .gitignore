# -----------------------
# Base exclusions
# -----------------------
*.pyc
*.pyo
__pycache__/
*.log
*.swp
*.bak
.DS_Store
.env
.env.*
.vagrant/

# -----------------------
# storage/: keep dir structure, ignore all files
# -----------------------
storage/**/*
!storage/
!storage/**/
!storage/**/.gitkeep

# -----------------------
# llms/: same behavior
# -----------------------
storage/llms/**/*
!storage/llms/
!storage/llms/**/
!storage/llms/**/.gitkeep

# ----------------------
# Shell script conventions
# ----------------------
*.sh text eol=lf
*.sh text eol=lf diff

# -----------------------
# Kubernetes
# -----------------------
/var/log/k3s.log
/etc/rancher/k3s/k3s.yaml
*.kube/config
*.kube/
kubeconfig
k3s.yaml

# -----------------------
# Logs and system files
# -----------------------
*.log
*.pid
*.sock

# -----------------------
# Python venv and build
# -----------------------
.venv/
venv/
ENV/
env/
*.egg
*.egg-info/
.eggs/
.cache/
.mypy_cache/
.pytest_cache/
.coverage
coverage.xml
htmlcov/
get-docker.sh

# -----------------------
# VS Code, dev containers, editors
# -----------------------

.devcontainer/.python-version
.idea/
*.sublime-project
*.sublime-workspace
Thumbs.db
desktop.ini

# -----------------------
# Temp & dev scratch
# -----------------------
temp/
*.tmp

# -----------------------
# Jupyter/IPython
# -----------------------

*.out

# -----------------------
# Frontend artifacts
# -----------------------
inference_pipeline/api/frontend/node_modules/
inference_pipeline/api/frontend/dist/
inference_pipeline/api/frontend/.vite/

# -----------------------
# Build/test artifacts
# -----------------------
build/
dist/
*.egg-info/

# -----------------------
# Infra artifacts
# -----------------------
models/
models/**
.aws/
*.pem
*.key
*.crt

*.tsbuildinfo



*.map

**/checkpoints/
**/cache/

# -----------------------
# Final fallback safety
# -----------------------
**/*.bak
**/*.tmp
**/*.log

# -----------------------
# Allowlist essential tracked files
# -----------------------
!README.md
!Makefile
!.gitignore
!requirements.txt

# Non-repo stuff
.gitlab/
.githooks/
